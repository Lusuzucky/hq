# Hermes 环境变量（示例）
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ── API Keys ──────────────────────────
DEEPSEEK_API_KEY=sk-your-key
OPENAI_API_KEY=ollama
TAVILY_API_KEY=tvly-dev-your-key

# ── QQ Bot ────────────────────────────
QQ_APP_ID=
QQ_CLIENT_SECRET=
QQ_ALLOW_ALL_USERS=true
QQ_ALLOWED_USERS=
QQBOT_HOME_CHANNEL=

# ── Idle Nudge ────────────────────────
QQ_IDLE_NUDGE_ENABLED=true
QQ_IDLE_NUDGE_MIN_MINUTES=20
QQ_IDLE_NUDGE_MAX_MINUTES=90

# ── Auto Continue ─────────────────────
QQ_AUTO_CONTINUE_ENABLED=false
QQ_AUTO_CONTINUE_MIN_SECONDS=20
QQ_AUTO_CONTINUE_MAX_SECONDS=30
QQ_AUTO_CONTINUE_MAX_ROUNDS=3

# ── Message Coalesce ──────────────────
QQ_COALESCE_DELAY_SECONDS=10

# ── First Message Suffix ──────────────
QQ_FIRST_MESSAGE_SUFFIX=

# ── PC / WOL ──────────────────────────
WOL_MAC=d8:43:ae:2d:92:3d
PC_IP=10.10.10.5

# ── External Services ─────────────────
COMFYUI_BASE_URL=http://10.10.10.5:8188
JOYAGENT_API_KEY=
GPTSOVITS_BASE_URL=http://10.10.10.5:9880
